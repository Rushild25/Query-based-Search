# Copy this file to .env and fill in real values.
# LLM
LLM_PROVIDER=google_genai
LLM_FALLBACK_PROVIDER=groq

# Gemini primary
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_GENAI_MODEL=gemini-2.0-flash

# Groq fallback (used for chat fallback and optional visual fallback)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
LLM_TEMPERATURE=0.1

# Qdrant Cloud
QDRANT_URL=https://YOUR-QDRANT-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=research_chunks
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT_SECONDS=120
QDRANT_UPSERT_TIMEOUT_SECONDS=180
QDRANT_UPSERT_BATCH_SIZE=24
VECTOR_DB_PROVIDER=qdrant

# Embeddings (huggingface | openai)
EMBEDDING_PROVIDER=clip
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64

# CLIP visual embeddings (ingestion-time image + text retrieval)
RAG_VISUAL_EMBEDDINGS_ENABLED=true
VISUAL_EMBEDDING_PROVIDER=clip
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
QDRANT_VISUAL_COLLECTION=research_visual_chunks
VISUAL_EMBEDDING_BATCH_SIZE=24

# Optional OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional Hugging Face token (for gated models/endpoints)
HUGGINGFACEHUB_API_TOKEN=YOUR_HUGGINGFACE_TOKEN